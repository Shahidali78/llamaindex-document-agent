# Root env for docker compose. Copy to ".env" and set your key.
# These are passed through to the backend container.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=*

# --- Authentication ---
AUTH_ENABLED=true
API_KEYS=dev-local-key
ADMIN_API_TOKEN=change-me-admin-token

# Browser-reachable backend URL baked into the frontend at build time.
VITE_API_BASE_URL=http://localhost:8000
