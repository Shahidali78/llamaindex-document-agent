# Copy this file to ".env" and fill in your values. NEVER commit your real .env.

# --- OpenAI (required for AI endpoints) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- App ---
APP_NAME=LlamaIndex AI Document Intelligence Platform
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins ("*" allows all)
CORS_ORIGINS=*

# --- Authentication ---
# When true, data/AI endpoints require an 'X-API-Key' header.
AUTH_ENABLED=true
# Quick start: one or more comma-separated static keys (no minting needed).
API_KEYS=dev-local-key
# Admin token that unlocks the /auth key-management API (POST/GET/DELETE /auth/keys).
# Leave empty to disable minting and rely solely on API_KEYS above.
ADMIN_API_TOKEN=change-me-admin-token

# --- Indexing / retrieval ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
SIMILARITY_TOP_K=4
MAX_EXTRACT_CHARS=24000
MAX_UPLOAD_MB=25

# --- Storage (optional override; defaults to backend/data) ---
# DATA_DIR=C:/MY_Projects/llamaindex-document-agent/backend/data
